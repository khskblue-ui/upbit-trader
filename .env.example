# ================================================================
# upbit-trader 환경 변수 설정 예시
# cp .env.example .env  후 값을 채워주세요.
# ================================================================

# 업비트 API 키 (실거래/페이퍼 모드 필수, 백테스트 불필요)
UPBIT_ACCESS_KEY=your_access_key_here
UPBIT_SECRET_KEY=your_secret_key_here

# 텔레그램 알림 (선택)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# 거래 모드: backtest | paper | live
TRADING_MODE=backtest

# 로그 레벨: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# 데이터베이스
DATABASE_URL=sqlite+aiosqlite:///data/trading.db
